rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // profiles
    match /profiles/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;

      match /following/{targetId} {
        allow read: if isAuth();
        allow write: if isOwner(uid);
      }
      match /followers/{followerId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == followerId;
      }
      match /muted/{targetId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }
    }

    // posts
    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['heartCount', 'echoCount', 'replyCount'])
      );
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;

      match /hearts/{userId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
      match /echoes/{userId} {
        allow read: if isAuth();
        allow write: if isOwner(userId);
      }
      match /replies/{replyId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuth() && (
          resource.data.userId == request.auth.uid ||
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['heartCount'])
        );
        allow delete: if isAuth() && resource.data.userId == request.auth.uid;

        match /hearts/{userId} {
          allow read: if isAuth();
          allow write: if isOwner(userId);
        }
      }
    }

    // notifications
    match /notifications/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);

      match /items/{itemId} {
        allow read: if isOwner(uid);
        allow write: if isAuth();
      }
    }

    // bookmarks
    match /bookmarks/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);

      match /posts/{postId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }
    }

    // conversations
    match /conversations/{convId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants
                        && request.resource.data.senderId == request.auth.uid;
        allow update: if false;
        allow delete: if false;
      }
    }

    // circles
    match /circles/{circleId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth();
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;

      match /messages/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
